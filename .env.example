# Copy this file to `.env` and fill in real values before running `docker compose up`.
# Never commit the real `.env` file.

# Postgres / PostGIS
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://postgres:changeme@127.0.0.1:5432/fluxfang

# Backend application secrets (placeholders for now — used starting Phase 1+)
FLUXFANG_SESSION_KEY=changeme-session-key
FLUXFANG_SECRET_KEY=changeme-secret-key

# Hardware devices for the backend's wifi/gps scanning (optional; only needed
# once real hardware capture is wired up — not required to boot the health skeleton).
# WIFI_DEVICE=wlan1
# GPS_DEVICE=/dev/ttyUSB0
