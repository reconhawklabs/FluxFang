# Copy this file to `.env` and fill in real values before running `docker compose up`.
# Never commit the real `.env` file.

# Postgres / PostGIS
POSTGRES_PASSWORD=changeme
# Application database name. The `db` service creates it on first init and the
# backend connects to it via DATABASE_URL below (the two must agree).
POSTGRES_DB=fluxfang
DATABASE_URL=postgres://postgres:changeme@127.0.0.1:5432/fluxfang

# Backend application secrets (placeholders for now — used starting Phase 1+)
# FLUXFANG_SESSION_KEY is reserved but NOT used yet (Task 2.2): sessions run
# on tower-sessions' MemoryStore, whose cookie only ever carries an opaque,
# server-generated session id (no client-editable payload for a signature to
# protect), so cookie signing has no security payoff today. It's left wired
# up here for whichever future task adopts a persistent/signed session store.
FLUXFANG_SESSION_KEY=changeme-session-key

# FLUXFANG_SECRET_KEY (Task 6.2): base64-encoded 32 random bytes, used to
# AES-256-GCM encrypt/decrypt `alert_method.config_encrypted` at rest. Loaded
# at backend startup via `fluxfang_core::secrets::key_from_base64`, which
# requires *exactly* 32 decoded bytes -- an invalid value makes the backend
# fail fast at startup rather than limping along with broken alert-method
# credentials. The value below is a real, randomly generated 32-byte key
# (safe as a placeholder since it's committed in this example file) — for an
# actual deployment, generate your own, e.g.: `openssl rand -base64 32`.
FLUXFANG_SECRET_KEY=jc1X3acW9hyU5t+SVJso/UA55j0UxaVmSCjFHgNCoII=

# Session cookie `Secure` flag (Task 2.2). Defaults to false since nothing in
# this stack terminates TLS yet (see frontend/nginx.conf) — browsers silently
# drop `Secure` cookies sent over plain HTTP. Set to true once TLS fronts this.
# FLUXFANG_SESSION_SECURE=false

# Hardware devices for the backend's wifi/gps scanning. Both are OPTIONAL —
# leave unset and the stack still comes up fine (add/start Data Sources later
# from the WebUI once hardware is attached, or run entirely on the built-in
# mock capturer for development/demo purposes).
#
# WIFI_DEVICE: the *interface name* of a monitor-mode-capable wifi adapter
# (check with `iw dev`). No `devices:` passthrough is needed for this one —
# docker-compose.yml runs the backend with `network_mode: host` +
# `privileged: true` + `NET_ADMIN`/`NET_RAW`, so host network interfaces are
# already visible to it by name.
# WIFI_DEVICE=wlan1
#
# GPS_DEVICE: only needed for a USB/serial GPS receiver (skip entirely if
# using a network gpsd server instead — just point the Data Source at
# `host:port` from the WebUI). When set, docker-compose.yml passes this path
# through to the container as a `--device` so the backend can open the
# serial port. Must match an existing character device on the host (check
# with `ls /dev/serial/by-id/` or `dmesg | grep tty` after plugging it in).
# GPS_DEVICE=/dev/ttyUSB0
